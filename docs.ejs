    .quick-card-desc {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* Section placeholders */
    .doc-section {
      margin-bottom: 64px;
    }

    .placeholder-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 2px solid var(--border);
      padding: 20px 24px;
      margin-top: 12px;
    }

    .placeholder-block p {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--muted);
      margin: 0;
      line-height: 1.7;
    }

    .placeholder-block p::before {
      content: "// ";
      color: var(--accent);
    }

    /* Code blocks */
    .code-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 2px solid var(--accent);
      padding: 18px 20px;
      margin: 12px 0 24px;
      overflow-x: auto;
    }

    .code-block pre {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--text);
      margin: 0;
      line-height: 1.75;
      white-space: pre;
    }

    .code-block pre .c { color: var(--muted); }
    .code-block pre .k { color: var(--accent); }
    .code-block pre .s { color: #ffd27a; }
    .code-block pre .n { color: #a8d8ff; }

    /* Monaco overrides */
    .code-block.monaco-active {
      padding: 0;
      overflow: hidden;
    }

    .code-block .monaco-editor .cursor {
      opacity: 0 !important;
    }

    /* Parameter cards */
    .param-card {
      border: 1px solid var(--border);
      background: var(--surface);
      padding: 20px 22px;
      margin-bottom: 28px;
    }

    .param-header {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 10px;
    }

    .param-name {
      font-family: var(--mono);
      font-size: 0.88rem;
      color: var(--accent);
      letter-spacing: 0.04em;
    }

    .param-type {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 1px 7px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .param-desc {
      font-family: var(--mono);
      font-size: 0.75rem;
      color: var(--muted);
      line-height: 1.75;
      margin: 0 0 14px;
    }

    .param-desc strong {
      color: var(--text);
      font-weight: normal;
    }

    .param-demo-label {
      font-family: var(--display);
      font-weight: 700;
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .param-card .code-block {
      margin: 0;
      border-left-color: var(--border);
    }

    /* Return value table */
    .return-table {
      width: 100%;
      border-collapse: collapse;
      margin: 12px 0 0;
    }

    .return-table th,
    .return-table td {
      font-family: var(--mono);
      font-size: 0.72rem;
      text-align: left;
      padding: 9px 14px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }

    .return-table th {
      color: var(--muted);
      font-size: 0.63rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-bottom-color: var(--accent);
    }

    .return-table td:first-child {
      color: var(--accent);
      white-space: nowrap;
    }

    .return-table td:nth-child(2) {
      color: var(--muted);
      white-space: nowrap;
    }

    .return-table td:nth-child(3) {
      color: var(--muted);
      line-height: 1.65;
    }

    .sidebar-link.sub {
      padding-left: 34px;
      font-size: 0.67rem;
    }

    @media (max-width: 860px) {
      .docs-wrap {
        grid-template-columns: 1fr;
      }

      .docs-sidebar {
        display: none;
      }

      .docs-main {
        padding: 32px 20px;
      }
    }
  </style>
</head>

