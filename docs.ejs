      <!-- BOT API -->
      <div class="doc-section" id="bot-api">
        <h2 class="docs-h2"><i class="bi bi-cpu"></i> Bot API</h2>
        <p class="docs-p">
          Your bot is a JavaScript file that defines a function called <code>compute</code>.
          The game calls it once per tick (60&thinsp;fps) and uses the returned action to drive
          your companion character. Write your bot in the in-game editor under
          <strong>Options → Bots</strong>, or in the <strong>Practice</strong> sandbox.
        </p>

        <div class="docs-h3">The compute function</div>
        <p class="docs-p">
          Define a global function named exactly <code>compute</code>. It receives one
          argument — a context object — and must return an action object.
        </p>

        <div class="code-block"><pre>function compute({ now, me, companion, players }) {

  // ... your logic here ...

  return {
    turn:     0,      // -1 (left) → 1 (right)
    throttle: 0,      //  0 (stop) → 1 (full speed)
    shoot:    false,  // true to fire
  };
}</pre></div>

        <p class="docs-p">
          The function runs inside a sandboxed <code>Function()</code> constructor — no
          access to <code>document</code>, <code>window</code>, or the network. Side effects
          are allowed (closures, module-level variables) so you can keep state between ticks.
          If your function throws or takes longer than 6&thinsp;ms, the frame is skipped and a
          warning is logged to the console.
        </p>
      </div>

      <hr class="docs-divider">

      <!-- BOT INPUTS -->
      <div class="doc-section" id="bot-inputs">
        <h2 class="docs-h2"><i class="bi bi-braces"></i> Parameters</h2>
        <p class="docs-p">
          The context object destructured into <code>{ now, me, companion, players }</code>
          describes the current game state from your team's perspective. Enemies are
          only included if at least one of your units can see them (line-of-sight,
          max&nbsp;320&thinsp;px).
        </p>

        <!-- now -->
        <div class="param-card" id="input-now">
          <div class="param-header">
            <span class="param-name">now</span>
            <span class="param-type">number · ms</span>
          </div>
          <p class="param-desc">
            A high-resolution timestamp in milliseconds from <strong>performance.now()</strong>.
            Increases every tick. Use it to implement your own cooldowns or timed behaviours
            without relying on tick counters.
          </p>
          <div class="param-demo-label">Demo — custom fire rate</div>
          <div class="code-block"><pre>let lastFiredAt = 0;

function compute({ now, companion, players }) {
  const FIRE_EVERY_MS = 600;

  // Only set shoot:true once per interval
  const fire = now - lastFiredAt > FIRE_EVERY_MS;
  if (fire) lastFiredAt = now;

  return { turn: 0, throttle: 0, shoot: fire };
}</pre></div>
        </div>

        <!-- me -->
        <div class="param-card" id="input-me">
          <div class="param-header">
            <span class="param-name">me</span>
            <span class="param-type">object · human player</span>
          </div>
          <p class="param-desc">
            Your human character — the one you control with the keyboard or gamepad.
            Use it to make the companion follow you or react to your position.<br><br>
            <strong>me.id</strong> — unique player ID string<br>
            <strong>me.x / me.y</strong> — world position in pixels (world is 900 × 540)<br>
            <strong>me.angle</strong> — facing direction in radians (0 = right, π/2 = down)<br>
            <strong>me.alive</strong> — false when eliminated
          </p>
          <div class="param-demo-label">Demo — stay close to the leader</div>
          <div class="code-block"><pre>function compute({ me, companion }) {
  if (!me || !me.alive) return { turn: 0, throttle: 0, shoot: false };

  const dx = me.x - companion.x;
  const dy = me.y - companion.y;
  const dist = Math.sqrt(dx * dx + dy * dy);

  // Don't crowd the leader
  if (dist < 80) return { turn: 0, throttle: 0, shoot: false };

  const targetAngle = Math.atan2(dy, dx);
  const delta = normAngle(targetAngle - companion.angle);

  return {
    turn:     clamp(delta * 1.5, -1, 1),
    throttle: clamp(dist / 200, 0.3, 1),
    shoot:    false,
  };
}

function normAngle(a) {
  while (a >  Math.PI) a -= Math.PI * 2;
  while (a < -Math.PI) a += Math.PI * 2;
  return a;
}

function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }</pre></div>
        </div>

        <!-- companion -->
        <div class="param-card" id="input-companion">
          <div class="param-header">
            <span class="param-name">companion</span>
            <span class="param-type">object · the bot you control</span>
          </div>
          <p class="param-desc">
            The companion character your script is driving. Its ID ends in <code>:c</code>
            (e.g. <code>"p1:c"</code>). Same shape as <code>me</code>.<br><br>
            <strong>companion.id</strong> — player ID (always ends in <code>:c</code>)<br>
            <strong>companion.x / companion.y</strong> — world position<br>
            <strong>companion.angle</strong> — current facing angle in radians<br>
            <strong>companion.alive</strong> — false when eliminated
          </p>
          <div class="param-demo-label">Demo — always spin</div>
          <div class="code-block"><pre>function compute({ companion }) {
  // Spin clockwise at full turn rate, stay still
  return { turn: 1, throttle: 0, shoot: false };
}</pre></div>
        </div>

        <!-- players -->
        <div class="param-card" id="input-players">
          <div class="param-header">
            <span class="param-name">players</span>
            <span class="param-type">Map&lt;string, player&gt;</span>
          </div>
          <p class="param-desc">
            A <strong>Map</strong> of all currently visible players, keyed by player ID.
            Your own team is always present. Enemies only appear when your human or companion
            has line-of-sight to them within 320&thinsp;px.<br><br>
            Each value has: <strong>x</strong>, <strong>y</strong>, <strong>angle</strong>,
            <strong>alive</strong>, <strong>kind</strong> (<code>"human"</code> or <code>"companion"</code>).<br><br>
            To tell teammates from enemies: player IDs on the same team share the same base
            string. A companion ID is the owner's ID plus <code>:c</code>. Strip <code>:c</code>
            from both IDs and compare.
          </p>
          <div class="param-demo-label">Demo — aim at nearest visible enemy</div>
          <div class="code-block"><pre>function compute({ companion, players }) {
  let nearest = null;
  let bestDist = Infinity;

  for (const [id, p] of players) {
    if (!p.alive)                    continue; // skip dead
    if (id === companion.id)         continue; // skip self
    if (sameTeam(companion.id, id)) continue; // skip teammates

    const dx = p.x - companion.x;
    const dy = p.y - companion.y;
    const dist = Math.sqrt(dx * dx + dy * dy);

    if (dist < bestDist) { bestDist = dist; nearest = p; }
  }

  if (!nearest) return { turn: 0, throttle: 0, shoot: false };

  const angle = Math.atan2(nearest.y - companion.y, nearest.x - companion.x);
  const delta = normAngle(angle - companion.angle);

  return {
    turn:     clamp(delta * 1.5, -1, 1),
    throttle: 0.6,
    shoot:    bestDist < 260,
  };
}

// IDs on the same team share the same base (strip :c suffix)
function sameTeam(a, b) {
  return a.replace(/:c$/, '') === b.replace(/:c$/, '');
}

function normAngle(a) {
  while (a >  Math.PI) a -= Math.PI * 2;
  while (a < -Math.PI) a += Math.PI * 2;
  return a;
}

function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }</pre></div>
