      <!-- BOT EXAMPLES -->
      <div class="doc-section" id="bot-examples">
        <h2 class="docs-h2"><i class="bi bi-code-slash"></i> Full Example</h2>
        <p class="docs-p">
          A complete "Ranger" strategy. When an enemy is visible the companion closes to
          medium range, holds position, and shoots. When no enemy is visible it falls back
          to escort the human. Pulling back when too close prevents getting cornered.
        </p>

        <div class="code-block"><pre>// ── Ranger bot ───────────────────────────────────────────────────────────────
// Behaviour:
//   - Visible enemy  → orbit at medium range and shoot
//   - No enemy       → escort the human player
// ─────────────────────────────────────────────────────────────────────────────

function compute({ now, me, companion, players }) {

  // ── 1. Find the nearest visible enemy ──────────────────────────────────────
  let target = null;
  let targetDist = Infinity;

  for (const [id, p] of players) {
    if (!p.alive)                    continue;
    if (id === companion.id)         continue;
    if (sameTeam(companion.id, id)) continue;

    const d = dist(companion, p);
    if (d < targetDist) { targetDist = d; target = p; }
  }

  // ── 2. Combat mode ─────────────────────────────────────────────────────────
  if (target) {
    const IDEAL_RANGE = 190;  // px — comfortable fighting distance
    const CLOSE_RANGE = 110;  // px — too close, back up
    const SHOOT_RANGE = 260;  // px — bullet range

    // Angle from companion to target
    const toTarget = Math.atan2(
      target.y - companion.y,
      target.x - companion.x
    );
    const delta = normAngle(toTarget - companion.angle);

    // Speed: negative = reverse, closes/opens gap
    let throttle;
    if (targetDist < CLOSE_RANGE)   throttle = -0.6;  // too close → retreat
    else if (targetDist > IDEAL_RANGE) throttle = 0.7; // too far   → advance
    else                             throttle =  0.1;  // in range  → drift

    return {
      turn:     clamp(delta * 1.6, -1, 1),
      throttle: throttle,
      shoot:    targetDist < SHOOT_RANGE,
    };
  }

  // ── 3. Escort mode — follow the human if no enemy is visible ───────────────
  if (!me || !me.alive) {
    // Human is gone — hold position
    return { turn: 0, throttle: 0, shoot: false };
  }

  const leaderDist = dist(companion, me);

  // Already close enough
  if (leaderDist < 80) return { turn: 0, throttle: 0, shoot: false };

  const toLeader = Math.atan2(me.y - companion.y, me.x - companion.x);
  const delta = normAngle(toLeader - companion.angle);

  return {
    turn:     clamp(delta * 1.5, -1, 1),
    throttle: clamp(leaderDist / 180, 0.3, 0.9),
    shoot:    false,
  };
}

// ── Helpers ───────────────────────────────────────────────────────────────────

function dist(a, b) {
  const dx = a.x - b.x;
  const dy = a.y - b.y;
  return Math.sqrt(dx * dx + dy * dy);
}

function normAngle(a) {
  while (a >  Math.PI) a -= Math.PI * 2;
  while (a < -Math.PI) a += Math.PI * 2;
  return a;
}

function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

function sameTeam(a, b) {
  return a.replace(/:c$/, '') === b.replace(/:c$/, '');
}</pre></div>

