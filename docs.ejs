  <style>
    /* ── Docs layout ── */
    .docs-wrap {
      display: grid;
      grid-template-columns: 240px 1fr;
      min-height: 100vh;
      padding-top: 60px;
      /* nav height */
    }

    /* Sidebar */
    .docs-sidebar {
      background: var(--surface);
      border-right: 1px solid var(--border);
      padding: 32px 0;
      position: sticky;
      top: 60px;
      height: calc(100vh - 60px);
      overflow-y: auto;
    }

    .sidebar-section-label {
      font-family: var(--mono);
      font-size: 0.58rem;
      color: var(--accent);
      letter-spacing: 0.28em;
      text-transform: uppercase;
      padding: 0 20px 10px;
      margin-top: 20px;
    }

    .sidebar-section-label:first-child {
      margin-top: 0;
    }

    .sidebar-link {
      display: block;
      font-family: var(--mono);
      font-size: 0.73rem;
      color: var(--muted);
      text-decoration: none;
      padding: 7px 20px;
      border-left: 2px solid transparent;
      transition: color 80ms, border-color 80ms, background 80ms;
      letter-spacing: 0.04em;
    }

    .sidebar-link:hover {
      color: var(--text);
      border-left-color: var(--border);
      background: var(--bg);
    }

    .sidebar-link.active {
      color: var(--accent);
      border-left-color: var(--accent);
    }

    /* Main content */
    .docs-main {
      padding: 56px 64px;
      max-width: 820px;
    }

    /* Nav */
    .docs-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(10, 10, 10, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }

    .docs-nav-links {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .docs-nav-link {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--muted);
      text-decoration: none;
      padding: 5px 12px;
      border: 1px solid transparent;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      transition: color 80ms, border-color 80ms;
    }

    .docs-nav-link:hover {
      color: var(--text);
      border-color: var(--border);
    }

    /* Docs content typography */
    .docs-eyebrow {
      font-family: var(--mono);
      font-size: 0.63rem;
      color: var(--accent);
      letter-spacing: 0.28em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }

    .docs-h1 {
      font-family: var(--display);
      font-weight: 900;
      font-size: clamp(2.5rem, 5vw, 3.8rem);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      line-height: 1;
      margin: 0 0 24px;
    }

    .docs-lead {
      font-family: var(--mono);
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.85;
      margin-bottom: 48px;
      max-width: 580px;
    }

    .docs-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 48px 0;
    }

    .docs-h2 {
      font-family: var(--display);
      font-weight: 900;
      font-size: 1.6rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin: 0 0 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .docs-h2 i {
      color: var(--accent);
      font-size: 1.2rem;
    }

    .docs-h3 {
      font-family: var(--display);
      font-weight: 700;
      font-size: 1.05rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin: 28px 0 12px;
      color: var(--text);
    }

    .docs-p {
      font-family: var(--mono);
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.85;
      margin-bottom: 18px;
    }

    .docs-p a {
      color: var(--accent);
      text-decoration: none;
    }

    .docs-p a:hover {
      text-decoration: underline;
    }

    .docs-p code {
      font-family: var(--mono);
      font-size: 0.75rem;
      color: var(--text);
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 1px 6px;
    }

    /* WIP notice */
    .wip-banner {
      background: var(--accent-dim);
      border: 1px solid var(--accent);
      border-left: 3px solid var(--accent);
      padding: 16px 20px;
      margin-bottom: 40px;
    }

    .wip-banner-title {
      font-family: var(--display);
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 6px;
    }

    .wip-banner-body {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--muted);
      line-height: 1.7;
    }

    .wip-banner-body a {
      color: var(--accent);
      text-decoration: none;
    }

    /* Quick nav cards */
    .quick-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2px;
      margin-bottom: 52px;
    }

    .quick-card {
      background: var(--surface);
      border: 1px solid var(--border);
